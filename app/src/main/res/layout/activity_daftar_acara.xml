<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ===== HEADER: Total Tabungan + Progress Pill ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Halo, Najwa!"
                android:textSize="16sp"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="@font/inter" />

            <TextView
                android:id="@+id/tvLabelTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="TOTAL TABUNGAN KAMU"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:textColor="@color/secondary"
                android:fontFamily="@font/inter" />

            <TextView
                android:id="@+id/tvTotalTabungan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Rp 2.450.000"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter"
                android:textColor="@color/on_surface" />

            <!-- Progress Bar Pill Besar -->
            <ProgressBar
                android:id="@+id/progressTotal"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:layout_marginTop="16dp"
                android:progressDrawable="@drawable/progress_pill_drawable"
                android:max="100"
                android:progress="62" />

            <TextView
                android:id="@+id/tvProgressCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="62% dari target • Rp 1.500.000 lagi"
                android:textSize="14sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/on_surface_variant" />
        </LinearLayout>

        <!-- ===== SECTION LABEL ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="24dp"
            android:text="ACARA KAMU"
            android:textSize="13sp"
            android:letterSpacing="0.08"
            android:textStyle="bold"
            android:fontFamily="@font/inter"
            android:textColor="@color/on_surface_variant" />

        <!-- ===== LIST ACARA ===== -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAcara"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="24dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_acara"
            xmlns:tools="http://schemas.android.com/tools" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>