<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_back"
                    android:contentDescription="Back" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btnEditEvent"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="20dp"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/primary"
                    android:contentDescription="Edit acara" />

                <ImageView
                    android:id="@+id/btnDeleteEvent"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="20dp"
                    android:src="@drawable/ic_delete"
                    app:tint="#d9534f"
                    android:contentDescription="Hapus acara" />

                <ImageView
                    android:id="@+id/btnNotification"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_notification"
                    app:tint="@color/primary"
                    android:contentDescription="Notification" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="8dp">

                <TextView
                    android:id="@+id/tvEventName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trip ke Bandung"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/tvEventLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="📍 Bandung, Jawa Barat • 12 Agu 2026"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/on_surface_variant" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TERKUMPUL"
                            android:textSize="12sp"
                            android:letterSpacing="0.08"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/on_surface_variant" />

                        <TextView
                            android:id="@+id/tvNominalTerkumpul"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rp 1.720.000"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TARGET"
                            android:textSize="12sp"
                            android:letterSpacing="0.08"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/on_surface_variant" />

                        <TextView
                            android:id="@+id/tvNominalTarget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rp 3.500.000"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressEvent"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:layout_marginTop="16dp"
                    android:progressDrawable="@drawable/progress_pill_drawable"
                    android:max="100"
                    android:progress="49" />

                <TextView
                    android:id="@+id/tvProgressCaption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="49% tercapai • Rp 1.780.000 lagi menuju target"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/on_surface_variant" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:paddingHorizontal="24dp"
                android:text="ALLOCATIONS"
                android:textSize="13sp"
                android:letterSpacing="0.08"
                android:textStyle="bold"
                android:fontFamily="@font/inter"
                android:textColor="@color/secondary" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAllocations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="24dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_detail_allocation" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddAllocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/ic_add"
        app:tint="@android:color/white"
        app:backgroundTint="@color/primary"
        app:fabSize="normal"
        android:contentDescription="Tambah Alokasi" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        style="@style/BottomNavStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:menu="@menu/menu_bottom_nav"
        app:elevation="0dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>