<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/border_mint_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Baris atas: Chip kategori + tanggal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipKategori"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIBURAN"
                android:textSize="12sp"
                app:chipCornerRadius="999dp"
                app:chipBackgroundColor="@color/tertiary_container"
                android:textColor="@color/tertiary"
                app:chipStrokeWidth="0dp"
                app:ensureMinTouchTargetSize="false" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvTanggal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 Agu 2026"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/on_surface_variant" />
        </LinearLayout>

        <!-- Nama Acara -->
        <TextView
            android:id="@+id/tvNamaAcara"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Trip ke Bandung"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter"
            android:textColor="@color/on_surface" />

        <!-- Lokasi -->
        <TextView
            android:id="@+id/tvLokasi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="📍 Bandung, Jawa Barat"
            android:textSize="14sp"
            android:fontFamily="@font/inter"
            android:textColor="@color/on_surface_variant" />

        <!-- Progress bar pill -->
        <ProgressBar
            android:id="@+id/progressAcara"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="16dp"
            android:progressDrawable="@drawable/progress_pill_drawable"
            android:max="100"
            android:progress="40" />

        <!-- Baris bawah: nominal + persen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/tvNominal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rp 800.000 / Rp 2.000.000"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/on_surface_variant" />

            <TextView
                android:id="@+id/tvPersen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="40%"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter"
                android:textColor="@color/primary" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>