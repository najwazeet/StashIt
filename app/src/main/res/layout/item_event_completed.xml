<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="32dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#ffffff"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Icon lingkaran -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_icon_circle_pink"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/ivCategoryIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_flight"
                app:tint="@color/primary" />
        </FrameLayout>

        <!-- Judul -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Bali Trip"
            android:textColor="#1a1a1a"
            android:textStyle="bold"
            android:textSize="16sp"
            android:fontFamily="@font/inter"
            app:layout_constraintTop_toTopOf="@id/iconContainer"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintEnd_toStartOf="@id/tvDate" />

        <!-- Tanggal -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 Agu 2026"
            android:textColor="#8a8a8a"
            android:textSize="12sp"
            android:fontFamily="@font/inter"
            app:layout_constraintTop_toTopOf="@id/tvTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Nominal -->
        <TextView
            android:id="@+id/tvNominal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:text="Rp 3.500.000 / 5.000.000"
            android:textColor="#5a5a5a"
            android:textSize="12sp"
            android:fontFamily="@font/inter"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintEnd_toStartOf="@id/tvPercentage" />

        <!-- Persentase -->
        <TextView
            android:id="@+id/tvPercentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="70%"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:textSize="14sp"
            android:fontFamily="@font/inter"
            app:layout_constraintTop_toTopOf="@id/tvNominal"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Progress bar pill -->
        <ProgressBar
            android:id="@+id/progressEvent"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_marginTop="10dp"
            android:max="100"
            android:progress="70"
            android:progressDrawable="@drawable/progress_pill_green"
            app:layout_constraintTop_toBottomOf="@id/tvNominal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>