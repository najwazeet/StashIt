<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".SignUpActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Top bar: back + title -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_back_arrow"
                    android:contentDescription="Back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="stash.it"
                    android:textSize="18sp"
                    android:fontFamily="@font/inter_18pt_bold"
                    android:textColor="@color/primary" />
            </RelativeLayout>

            <!-- Ilustrasi: placeholder dulu, nanti diisi -->
            <FrameLayout
                android:id="@+id/frameIllustration"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_illustration_card" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Join stash.it"
                android:textSize="22sp"
                android:fontFamily="@font/inter_18pt_bold"
                android:textColor="@color/text_dark" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Start your journey to smarter savings today."
                android:textSize="13sp"
                android:fontFamily="@font/inter_18pt_regular"
                android:textColor="@color/text_gray" />

            <!-- Full Name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Full Name"
                android:textSize="13sp"
                android:fontFamily="@font/inter_18pt_regular"
                android:textColor="@color/text_dark" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_field_rounded"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_person" />

                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@android:color/transparent"
                    android:hint="Enter your full name"
                    android:textColorHint="@color/text_gray"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_18pt_regular"
                    android:inputType="textPersonName"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Email Address"
                android:textSize="13sp"
                android:fontFamily="@font/inter_18pt_regular"
                android:textColor="@color/text_dark" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_field_rounded"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_email" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@android:color/transparent"
                    android:hint="name@example.com"
                    android:textColorHint="@color/text_gray"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_18pt_regular"
                    android:inputType="textEmailAddress"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- Password -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Password"
                android:textSize="13sp"
                android:fontFamily="@font/inter_18pt_regular"
                android:textColor="@color/text_dark" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_field_rounded"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_lock" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@android:color/transparent"
                    android:hint="Min. 8 characters"
                    android:textColorHint="@color/text_gray"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_18pt_regular"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/ivTogglePassword"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_view"
                    android:contentDescription="Toggle password visibility" />
            </LinearLayout>

            <!-- Checkbox terms -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="top">

                <CheckBox
                    android:id="@+id/cbTerms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:buttonTint="@color/mint_primary" />

                <TextView
                    android:id="@+id/tvTerms"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_18pt_regular"
                    android:textColor="@color/text_gray"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

            <!-- Create Account button -->
            <Button
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:text="Create Account"
                android:textSize="16sp"
                android:fontFamily="@font/inter_18pt_bold"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/mint_primary"
                app:icon="@drawable/ic_arrow_right"
                app:iconGravity="textEnd"
                app:iconTint="@color/white"
                app:cornerRadius="20dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.StashIt.Button"
                style="@style/Widget.MaterialComponents.Button" />

            <!-- OR divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider_gray" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:text="OR JOIN WITH"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_18pt_regular"
                    android:letterSpacing="0.05"
                    android:textColor="@color/text_gray" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider_gray" />
            </LinearLayout>

            <!-- Google + Apple -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGoogle"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Google"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_18pt_bold"
                    android:textAllCaps="false"
                    android:textColor="@color/text_dark"
                    android:backgroundTint="@color/white"
                    app:icon="@drawable/ic_google"
                    app:iconGravity="textStart"
                    app:cornerRadius="20dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.StashIt.Button"
                    app:strokeColor="@color/divider_gray"
                    app:strokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/btnApple"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Apple"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_18pt_bold"
                    android:textAllCaps="false"
                    android:textColor="@color/text_dark"
                    android:backgroundTint="@color/white"
                    app:icon="@drawable/ic_apple"
                    app:iconGravity="textStart"
                    app:cornerRadius="20dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.StashIt.Button"
                    app:strokeColor="@color/divider_gray"
                    app:strokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Footer: Login -->
    <LinearLayout
        android:id="@+id/layoutLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account? "
            android:textSize="13sp"
            android:fontFamily="@font/inter_18pt_regular"
            android:textColor="@color/text_gray" />

        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Login"
            android:textSize="13sp"
            android:fontFamily="@font/inter_18pt_bold"
            android:textColor="@color/mint_primary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>